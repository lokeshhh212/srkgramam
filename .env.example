# Copy this file to .env and fill in real values before deploying.
# Never commit the real .env file to version control.

# A long, random string used to sign JWT cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

# Database connection string.
# SQLite (default, fine for local dev only - Vercel has NO persistent disk,
# so SQLite CANNOT be used there; a fresh empty DB would appear on every
# cold start and any writes would vanish):
DATABASE_URL=sqlite:///./village_portal.db

# Neon Postgres (required when deploying to Vercel):
# 1. Create a free project at https://neon.tech (no credit card required).
# 2. In the Neon console, go to Connection Details and copy the connection
#    string that uses the POOLED host (it contains "-pooler" in the
#    hostname) - this matters on Vercel because serverless functions can
#    spin up many parallel instances, and Neon's pooler is built to handle
#    that; the direct (non-pooled) host can run out of connections quickly.
# 3. Paste it below. "postgres://" and "postgresql://" are both fine - the
#    app normalizes either automatically.
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
#
# (Render/Railway also work with a normal, non-pooled Postgres URL:)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ----------------------------------------------------------------------------
# CORS - only matters once something other than this same web app calls the
# /api/* endpoints directly (e.g. the Android/iOS app planned for later).
# Comma-separated list of allowed origins. Leave unset/"*" while developing;
# lock it down once you know your app's real origin(s).
# ----------------------------------------------------------------------------
# ALLOWED_ORIGINS=https://your-app.vercel.app,capacitor://localhost

# Set automatically by Vercel - do not set manually. Used to auto-enable
# Secure cookies and the Neon-friendly connection pooling above.
# VERCEL=1

# ----------------------------------------------------------------------------
# Cloudinary - free cloud storage for event photos/videos/documents.
# Why: free hosting platforms usually have no persistent disk (or wipe it on
# every redeploy), so event media is stored here instead of on the server.
#
# 1. Sign up free (no credit card required): https://cloudinary.com/users/register_free
# 2. Copy "Cloud name", "API Key", and "API Secret" from your Cloudinary
#    dashboard (Settings > Access Keys) and paste them below.
# 3. The free plan renews a generous storage + bandwidth allowance every month
#    and keeps uploaded files with no expiry date - plenty for a village portal.
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: change the base folder event media is organized under in Cloudinary.
CLOUDINARY_FOLDER=village-portal/events
